# ─ Server ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─ Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://carbonshift:carbonshift123@localhost:5432/carbonshift

# ─ Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ─ Admin seed (created on server boot if not exists) ──────────────────
ADMIN_SEED_EMAIL=admin@carbonshift.local
ADMIN_SEED_PASSWORD=admin123

# ─ Firebase (optional — leave empty for JWT-only dev mode) ────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─ Redis (optional) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
